{
  "expo": {
    "name": "MercyHome",
    "slug": "mercy-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdf8f0"
    },
    "scheme": "mercyhome",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ng.name.sescoconcept.mercyhome"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fdf8f0"
      },
      "package": "ng.name.sescoconcept.mercyhome"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4790edf4-a4e7-48a6-a1d9-14bac0f2719e"
      }
    },
    "owner": "sescodtech"
  }
}
